# theme
theme = Atom One Light

# font
font-family = JetBrains Mono
font-size = 13
adjust-underline-thickness = 3

# cursor
cursor-style = bar
cursor-style-blink = true
adjust-cursor-thickness = 3
shell-integration-features = no-cursor

# window
window-padding-x = 4
window-padding-y = 4

# selection
copy-on-select = clipboard

# macos
macos-option-as-alt = true

# keybinds: new_split / close_surface
keybind = ctrl+shift+right=new_split:right
keybind = ctrl+shift+left=new_split:left
keybind = ctrl+shift+up=new_split:up
keybind = ctrl+shift+down=new_split:down
keybind = ctrl+shift+w=close_surface

# keybinds: goto_split
keybind = ctrl+super+right=goto_split:right
keybind = ctrl+super+left=goto_split:left
keybind = ctrl+super+up=goto_split:up
keybind = ctrl+super+down=goto_split:down
